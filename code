server <- function(input, output, session) {
  
  # Reactive values
  values <- reactiveValues(
    raw_data = NULL,
    processed_data = NULL,
    target = NULL,
    problem_type = NULL,
    models = NULL,
    best_model_name = NULL,
    best_model = NULL,
    clustering_result = NULL,
    preproc_log = NULL,
    train_test_split = NULL,
    feature_selection_result = NULL,
    insights = NULL
  )
  
  # Load example dataset
  observeEvent(input$load_example, {
    # Use iris dataset for classification, mtcars for regression
    df <- iris
    values$raw_data <- df
    values$processed_data <- df
    values$target <- "Species"
    values$problem_type <- "classification"
    
    output$data_table <- renderDT({ datatable(df, options = list(scrollX = TRUE)) })
    output$data_summary <- renderPrint({
      cat("Rows:", nrow(df), "\nColumns:", ncol(df), "\n")
      cat("Column types:\n"); print(sapply(df, class))
    })
    updateSelectInput(session, "target_train", choices = names(df), selected = "Species")
    updateSelectInput(session, "viz_var", choices = names(df))
  })
  
  # File upload
  observeEvent(input$file, {
    req(input$file)
    df <- read.csv(input$file$datapath)
    values$raw_data <- df
    values$processed_data <- df
    values$target <- suggest_target(df)
    values$problem_type <- detect_problem_type(df, values$target)
    
    output$data_table <- renderDT({ datatable(df, options = list(scrollX = TRUE)) })
    output$data_summary <- renderPrint({
      cat("Rows:", nrow(df), "\nColumns:", ncol(df), "\n")
      cat("Column types:\n"); print(sapply(df, class))
    })
    
    # Update selectors
    updateSelectInput(session, "target_train", choices = c("None (Clustering)", names(df)), selected = values$target)
    updateSelectInput(session, "viz_var", choices = names(df))
  })
  
  # Data Overview outputs
  output$basic_info <- renderPrint({
    req(values$raw_data)
    df <- values$raw_data
    cat("Number of rows:", nrow(df), "\n")
    cat("Number of columns:", ncol(df), "\n")
    cat("Numeric columns:", sum(sapply(df, is.numeric)), "\n")
    cat("Categorical columns:", sum(sapply(df, function(x) is.factor(x) || is.character(x))), "\n")
    cat("Date columns:", sum(sapply(df, function(x) inherits(x, "Date"))), "\n")
  })
  
  output$missing_info <- renderPrint({
    req(values$raw_data)
    missing <- colSums(is.na(values$raw_data))
    if (sum(missing) == 0) cat("No missing values found.") else print(missing[missing > 0])
  })
  
  output$target_suggestion <- renderPrint({
    req(values$raw_data)
    cat("Suggested target column:", values$target, "\n")
    cat("Detected problem type:", values$problem_type, "\n")
    if (values$problem_type == "classification") {
      cat("Number of classes:", length(unique(values$raw_data[[values$target]])), "\n")
    } else if (values$problem_type == "regression") {
      cat("Target range:", paste(range(values$raw_data[[values$target]]), collapse = " to "), "\n")
    }
  })
  
  output$summary_stats <- renderDT({
    req(values$raw_data)
    df <- values$raw_data
    stats <- data.frame(
      Variable = names(df),
      Type = sapply(df, class),
      Missing = colSums(is.na(df)),
      Unique = sapply(df, function(x) length(unique(x))),
      Mean = sapply(df, function(x) if(is.numeric(x)) round(mean(x, na.rm=TRUE), 2) else NA),
      SD = sapply(df, function(x) if(is.numeric(x)) round(sd(x, na.rm=TRUE), 2) else NA)
    )
    datatable(stats, options = list(pageLength = 10))
  })
  
  # Visualization
  output$visualization_plot <- renderPlot({
    req(values$raw_data, input$viz_var)
    df <- values$raw_data
    var <- input$viz_var
    if (input$viz_type == "hist" && is.numeric(df[[var]])) {
      ggplot(df, aes_string(x = var)) + geom_histogram(fill = "steelblue", bins = 30) + theme_minimal()
    } else if (input$viz_type == "bar" && (is.factor(df[[var]]) || is.character(df[[var]]))) {
      ggplot(df, aes_string(x = var)) + geom_bar(fill = "coral") + theme_minimal() + coord_flip()
    } else if (input$viz_type == "box" && is.numeric(df[[var]])) {
      ggplot(df, aes_string(y = var)) + geom_boxplot(fill = "lightgreen") + theme_minimal()
    } else {
      ggplot() + annotate("text", x=1, y=1, label="Plot type not compatible with variable type", size=6) + theme_void()
    }
  })
  
  output$corr_heatmap <- renderPlot({
    req(values$raw_data, input$show_corr)
    df <- values$raw_data
    numeric_df <- df[, sapply(df, is.numeric), drop = FALSE]
    if (ncol(numeric_df) > 1) {
      corrplot(cor(numeric_df, use = "complete.obs"), method = "color", type = "upper", tl.cex = 0.8)
    }
  })
  
  # Preprocessing
  observeEvent(input$apply_preproc, {
    req(values$raw_data)
    df <- values$raw_data
    target <- if(!is.null(values$target) && values$target != "none") values$target else NULL
    
    preproc_result <- preprocess_data_advanced(
      df, target,
      handle_na = input$na_handling,
      outlier_method = input$outlier_handling,
      scale_method = input$scaling,
      encode_cats = input$encode_cats
    )
    values$processed_data <- preproc_result$data
    values$preproc_log <- preproc_result$log
    
    # Show before/after comparison (boxplot of first numeric column)
    output$preproc_comparison <- renderPlot({
      req(values$raw_data, values$processed_data)
      num_cols <- names(values$raw_data)[sapply(values$raw_data, is.numeric)]
      if (length(num_cols) > 0) {
        col_sel <- num_cols[1]
        before <- data.frame(Value = values$raw_data[[col_sel]], Stage = "Before")
        after <- data.frame(Value = values$processed_data[[col_sel]], Stage = "After")
        comp <- rbind(before, after)
        ggplot(comp, aes(x = Stage, y = Value, fill = Stage)) + geom_boxplot() + theme_minimal() +
          labs(title = paste("Comparison for", col_sel))
      }
    })
    
    output$preproc_log <- renderPrint({
      if (!is.null(values$preproc_log) && length(values$preproc_log) > 0) {
        cat("Preprocessing actions performed:\n")
        for (action in names(values$preproc_log)) {
          cat("-", action, ":", values$preproc_log[[action]], "\n")
        }
      } else {
        cat("No preprocessing applied yet.")
      }
    })
  })
  
  # Feature Selection
  observeEvent(input$run_fs, {
    req(values$processed_data, values$target, values$target != "none")
    method <- tolower(input$fs_method)
    if (method == "information gain") method <- "information_gain"
    if (method == "chi-square") method <- "chi_square"
    fs_result <- feature_selection(values$processed_data, values$target, method = method, top_n = input$top_n_features)
    values$feature_selection_result <- fs_result
    
    output$selected_features_table <- renderDT({
      req(fs_result)
      datatable(fs_result, options = list(pageLength = 10))
    })
    output$fs_plot <- renderPlot({
      req(fs_result)
      fs_result <- head(fs_result, input$top_n_features)
      ggplot(fs_result, aes(x = reorder(Feature, Score), y = Score)) + geom_bar(stat = "identity", fill = "darkgreen") + coord_flip() + theme_minimal() + labs(x = "Feature", y = "Score")
    })
  })
  
  # Model Training
  observeEvent(input$train_models, {
    req(values$processed_data)
    target <- input$target_train
    if (target == "None (Clustering)") {
      values$problem_type <- "clustering"
      values$target <- NULL
      showNotification("Clustering mode selected. Go to Clustering tab.", type = "info")
      return()
    }
    values$target <- target
    if (input$problem_type_manual == "auto") {
      values$problem_type <- detect_problem_type(values$processed_data, target)
    } else {
      values$problem_type <- input$problem_type_manual
    }
    
    # Split data
    set.seed(123)
    train_idx <- createDataPartition(values$processed_data[[target]], p = input$train_split/100, list = FALSE)
    train_data <- values$processed_data[train_idx, ]
    test_data <- values$processed_data[-train_idx, ]
    values$train_test_split <- list(train = train_data, test = test_data)
    
    output$train_status <- renderPrint({ cat("Training models for", values$problem_type, "...\nPlease wait.") })
    
    # Train models
    models <- train_models_enhanced(train_data, test_data, target, values$problem_type)
    values$models <- models
    
    # Determine best model
    if (values$problem_type == "classification") {
      best <- names(which.max(sapply(models, function(m) m$f1)))
    } else {
      best <- names(which.min(sapply(models, function(m) m$rmse)))
    }
    values$best_model_name <- best
    values$best_model <- models[[best]]
    
    output$train_status <- renderPrint({
      cat("Training complete.\n")
      cat("Best model:", values$best_model_name, "\n")
      if (values$problem_type == "classification") {
        cat("Accuracy:", round(values$best_model$accuracy * 100, 2), "%\n")
      } else {
        cat("RMSE:", round(values$best_model$rmse, 4), "\n")
      }
    })
    
    output$trained_models_table <- renderDT({
      if (is.null(values$models)) return(NULL)
      df_models <- data.frame(
        Model = names(values$models),
        stringsAsFactors = FALSE
      )
      if (values$problem_type == "classification") {
        df_models$Accuracy <- sapply(values$models, function(m) round(m$accuracy * 100, 2))
        df_models$F1 <- sapply(values$models, function(m) round(m$f1 * 100, 2))
      } else {
        df_models$RMSE <- sapply(values$models, function(m) round(m$rmse, 4))
        df_models$R2 <- sapply(values$models, function(m) round(m$rsq, 4))
      }
      datatable(df_models)
    })
    
    # Generate insights after training
    values$insights <- generate_insights(values$processed_data, target, values$problem_type, values$models, values$best_model_name)
  })
  
  # Model Evaluation outputs
  output$eval_metrics_table <- renderDT({
    req(values$best_model, values$problem_type)
    if (values$problem_type == "classification") {
      metrics <- data.frame(
        Metric = c("Accuracy", "Precision", "Recall", "F1 Score"),
        Value = c(values$best_model$accuracy, values$best_model$precision, values$best_model$recall, values$best_model$f1)
      )
      metrics$Value <- round(metrics$Value, 4)
      datatable(metrics)
    } else {
      metrics <- data.frame(
        Metric = c("RMSE", "MAE", "R-squared", "Adjusted R-squared"),
        Value = c(values$best_model$rmse, values$best_model$mae, values$best_model$rsq, values$best_model$adj_rsq)
      )
      metrics$Value <- round(metrics$Value, 4)
      datatable(metrics)
    }
  })
  
  output$eval_plot <- renderPlot({
    req(values$best_model, values$train_test_split, values$problem_type)
    test_data <- values$train_test_split$test
    target <- values$target
    actual <- test_data[[target]]
    pred <- values$best_model$predictions
    if (values$problem_type == "classification") {
      cm <- confusionMatrix(pred, actual)
      fourfoldplot(cm$table, color = c("lightblue", "lightcoral"), main = "Confusion Matrix")
    } else {
      df_plot <- data.frame(Actual = actual, Predicted = pred)
      ggplot(df_plot, aes(x = Actual, y = Predicted)) + geom_point(alpha = 0.6) + geom_abline(slope = 1, intercept = 0, color = "red") + theme_minimal() + labs(title = "Actual vs Predicted")
    }
  })
  
  output$roc_plot <- renderPlot({
    req(values$best_model, values$problem_type == "classification", values$train_test_split)
    if (values$problem_type == "classification" && length(unique(values$train_test_split$test[[values$target]])) == 2) {
      test_data <- values$train_test_split$test
      actual <- test_data[[values$target]]
      # For ROC need probabilities, approximate using model prediction confidence
      # For simplicity, use prediction as numeric if binary
      roc_curve <- roc(actual, as.numeric(values$best_model$predictions))
      plot(roc_curve, main = paste("ROC Curve - AUC =", round(auc(roc_curve), 3)))
    } else {
      plot(1, type="n", axes=F, xlab="", ylab=""); text(1,1, "ROC only for binary classification", cex=1.2)
    }
  })
  
  # Model Comparison
  output$comparison_table <- renderDT({
    req(values$models, values$problem_type)
    comp_df <- data.frame(Model = names(values$models), stringsAsFactors = FALSE)
    if (values$problem_type == "classification") {
      comp_df$Accuracy <- sapply(values$models, function(m) round(m$accuracy * 100, 2))
      comp_df$F1 <- sapply(values$models, function(m) round(m$f1 * 100, 2))
      comp_df <- comp_df[order(-comp_df$F1), ]
    } else {
      comp_df$RMSE <- sapply(values$models, function(m) round(m$rmse, 4))
      comp_df$R2 <- sapply(values$models, function(m) round(m$rsq, 4))
      comp_df <- comp_df[order(comp_df$RMSE), ]
    }
    datatable(comp_df)
  })
  
  output$comparison_bar <- renderPlot({
    req(values$models, values$problem_type)
    comp_df <- data.frame(Model = names(values$models), stringsAsFactors = FALSE)
    if (values$problem_type == "classification") {
      comp_df$Score <- sapply(values$models, function(m) m$accuracy)
      ggplot(comp_df, aes(x = reorder(Model, Score), y = Score, fill = Model)) + geom_bar(stat = "identity") + coord_flip() + theme_minimal() + labs(x = "Model", y = "Accuracy", title = "Model Accuracy Comparison")
    } else {
      comp_df$Score <- sapply(values$models, function(m) m$rmse)
      ggplot(comp_df, aes(x = reorder(Model, -Score), y = Score, fill = Model)) + geom_bar(stat = "identity") + coord_flip() + theme_minimal() + labs(x = "Model", y = "RMSE (lower better)", title = "Model RMSE Comparison")
    }
  })
  
  output$best_model_recommendation <- renderPrint({
    req(values$best_model_name, values$problem_type)
    cat("Best model for this dataset is", values$best_model_name, "\n")
    if (values$problem_type == "classification") {
      cat("Based on F1-score and Accuracy.\n")
    } else {
      cat("Based on lowest RMSE and highest R-squared.\n")
    }
    cat("Recommendation: Use this model for future predictions on similar data.\n")
  })
  
  # Clustering Tab
  observeEvent(input$run_clustering, {
    req(values$processed_data)
    clust_result <- perform_clustering_enhanced(values$processed_data, k_max = input$k_max_clust)
    if (!is.null(clust_result$error)) {
      showNotification(clust_result$error, type = "error")
      return()
    }
    values$clustering_result <- clust_result
    output$clustering_summary <- renderPrint({
      cat("Optimal number of clusters:", clust_result$optimal_k, "\n")
      cat("Total within-cluster SS:", round(clust_result$total_ss, 2), "\n")
      cat("Between-cluster SS:", round(clust_result$between_ss, 2), "\n")
      cat("Cluster sizes:\n"); print(table(clust_result$clusters))
    })
    output$elbow_silhouette <- renderPlot({
      df_elbow <- data.frame(k = clust_result$k_values, wss = clust_result$wss, sil = clust_result$sil_scores)
      p1 <- ggplot(df_elbow, aes(x = k, y = wss)) + geom_line() + geom_point() + theme_minimal() + labs(title = "Elbow Method")
      p2 <- ggplot(df_elbow, aes(x = k, y = sil)) + geom_line(color = "red") + geom_point(color = "red") + theme_minimal() + labs(title = "Silhouette Score")
      gridExtra::grid.arrange(p1, p2, ncol = 2)
    })
    output$cluster_pca <- renderPlot({
      ggplot(clust_result$pca_data, aes(x = PC1, y = PC2, color = cluster)) + geom_point(size = 3) + theme_minimal() + scale_color_brewer(palette = "Set1") + labs(title = "PCA Cluster Visualization")
    })
    output$cluster_summary_table <- renderDT({
      datatable(round(clust_result$cluster_summary, 3), options = list(scrollX = TRUE))
    })
  })
  
  # Insights Tab
  output$insights_text <- renderPrint({
    req(values$insights)
    cat(values$insights$type, "\n", paste(values$insights$text, collapse = "\n"), "\n")
    if (!is.null(values$clustering_result)) {
      cat("\nClustering additional insights:\n")
      cat("- Silhouette score:", round(mean(values$clustering_result$sil_scores), 3), "\n")
    }
  })
  
  output$trends_text <- renderPrint({
    req(values$raw_data)
    df <- values$raw_data
    numeric_cols <- names(df)[sapply(df, is.numeric)]
    if (length(numeric_cols) >= 2) {
      cat("Top correlations among numeric features:\n")
      cor_mat <- cor(df[, numeric_cols], use = "complete.obs")
      high_cor <- which(abs(cor_mat) > 0.7 & abs(cor_mat) < 1, arr.ind = TRUE)
      if (nrow(high_cor) > 0) {
        for (i in 1:nrow(high_cor)) {
          cat("-", rownames(cor_mat)[high_cor[i,1]], "vs", colnames(cor_mat)[high_cor[i,2]], ":", round(cor_mat[high_cor[i,1], high_cor[i,2]], 2), "\n")
        }
      } else {
        cat("No strong correlations found.\n")
      }
    }
    if (!is.null(values$best_model_name)) {
      cat("\nModel performance insight:\n")
      cat(values$best_model_name, "outperformed others due to its ability to capture complex patterns.\n")
    }
  })
  
  # Download Report (simplified - would generate R Markdown in full version)
  output$download_report_btn <- downloadHandler(
    filename = function() { paste("KDD_Report_", Sys.Date(), ".html", sep = "") },
    content = function(file) {
      # Simple HTML report
      report_html <- paste0(
        "<html><head><title>KDD Report</title></head><body>",
        "<h1>Professional KDD System Report</h1>",
        "<h2>Dataset Summary</h2>",
        "<pre>", capture.output(print(values$raw_data)), "</pre>",
        "<h2>Best Model</h2>",
        "<p>Best model: ", values$best_model_name, "</p>",
        "<h2>Insights</h2>",
        "<pre>", paste(values$insights$text, collapse = "\n"), "</pre>",
        "</body></html>"
      )
      writeLines(report_html, file)
    }
  )
  
}

# Run the application
shinyApp(ui = ui, server = server)
