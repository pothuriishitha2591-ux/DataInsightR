# Detect problem type automatically
detect_problem_type <- function(df, target_col) {
  if (target_col == "none" || is.null(target_col)) return("clustering")
  y <- df[[target_col]]
  if (is.numeric(y) && length(unique(y)) > 10) return("regression")
  return("classification")
}

# Suggest target column automatically
suggest_target <- function(df) {
  # Heuristic: last column or column with few unique values for classification
  # For regression, look for numeric with many unique values
  # For simplicity, return the last column name
  names(df)[ncol(df)]
}

# Generate dataset summary
dataset_summary <- function(df) {
  list(
    rows = nrow(df),
    cols = ncol(df),
    numeric_cols = names(df)[sapply(df, is.numeric)],
    categorical_cols = names(df)[sapply(df, function(x) is.factor(x) || is.character(x))],
    date_cols = names(df)[sapply(df, function(x) inherits(x, "Date") || inherits(x, "POSIXct"))],
    missing_summary = colSums(is.na(df))
  )
}

# Preprocessing with user options
preprocess_data_advanced <- function(df, target = NULL, 
                                      handle_na = "impute", 
                                      outlier_method = "iqr",
                                      scale_method = "standardize",
                                      encode_cats = TRUE,
                                      discretize_cols = NULL) {
  
  df_processed <- df
  changes_log <- list()
  
  # 1. Handle missing values
  if (handle_na != "none") {
    for (col in names(df_processed)) {
      if (any(is.na(df_processed[[col]]))) {
        if (is.numeric(df_processed[[col]])) {
          if (handle_na == "impute") {
            df_processed[[col]][is.na(df_processed[[col]])] <- median(df_processed[[col]], na.rm = TRUE)
            changes_log[[col]] <- "imputed with median"
          } else if (handle_na == "mean") {
            df_processed[[col]][is.na(df_processed[[col]])] <- mean(df_processed[[col]], na.rm = TRUE)
            changes_log[[col]] <- "imputed with mean"
          } else if (handle_na == "remove") {
            df_processed <- na.omit(df_processed)
            changes_log[["rows"]] <- "removed rows with missing values"
          }
        } else {
          mode_val <- names(sort(table(df_processed[[col]]), decreasing = TRUE))[1]
          df_processed[[col]][is.na(df_processed[[col]])] <- mode_val
          changes_log[[col]] <- "imputed with mode"
        }
      }
    }
  }
  
  # 2. Outlier handling
  if (outlier_method != "none") {
    numeric_cols <- names(df_processed)[sapply(df_processed, is.numeric)]
    for (col in numeric_cols) {
      Q1 <- quantile(df_processed[[col]], 0.25, na.rm = TRUE)
      Q3 <- quantile(df_processed[[col]], 0.75, na.rm = TRUE)
      IQR <- Q3 - Q1
      lower <- Q1 - 1.5 * IQR
      upper <- Q3 + 1.5 * IQR
      outliers <- df_processed[[col]] < lower | df_processed[[col]] > upper
      if (sum(outliers) > 0) {
        if (outlier_method == "iqr_cap") {
          df_processed[[col]][df_processed[[col]] < lower] <- lower
          df_processed[[col]][df_processed[[col]] > upper] <- upper
          changes_log[[col]] <- paste("capped", sum(outliers), "outliers")
        } else if (outlier_method == "remove") {
          df_processed <- df_processed[!outliers, ]
          changes_log[[col]] <- paste("removed", sum(outliers), "outliers")
        }
      }
    }
  }
  
  # 3. Scaling/Normalization
  numeric_cols <- names(df_processed)[sapply(df_processed, is.numeric)]
  if (scale_method != "none" && length(numeric_cols) > 0) {
    if (scale_method == "standardize") {
      preproc <- preProcess(df_processed[, numeric_cols, drop = FALSE], method = c("center", "scale"))
      df_processed[, numeric_cols] <- predict(preproc, df_processed[, numeric_cols, drop = FALSE])
      changes_log[["scaling"]] <- "standardized (mean=0, sd=1)"
    } else if (scale_method == "normalize") {
      preproc <- preProcess(df_processed[, numeric_cols, drop = FALSE], method = "range")
      df_processed[, numeric_cols] <- predict(preproc, df_processed[, numeric_cols, drop = FALSE])
      changes_log[["scaling"]] <- "normalized to [0,1]"
    }
  }
  
  # 4. Encode categorical variables
  if (encode_cats) {
    categorical_cols <- names(df_processed)[sapply(df_processed, function(x) is.factor(x) || is.character(x))]
    if (!is.null(target) && target %in% categorical_cols) {
      categorical_cols <- categorical_cols[categorical_cols != target]
    }
    if (length(categorical_cols) > 0) {
      dummy_formula <- as.formula(paste("~", paste(categorical_cols, collapse = "+")))
      dummies <- dummyVars(dummy_formula, data = df_processed, fullRank = TRUE)
      dummy_data <- predict(dummies, newdata = df_processed)
      dummy_df <- as.data.frame(dummy_data)
      df_processed <- df_processed[, !names(df_processed) %in% categorical_cols, drop = FALSE]
      df_processed <- cbind(df_processed, dummy_df)
      changes_log[["encoding"]] <- paste("encoded", length(categorical_cols), "categorical variables")
    }
  }
  
  # 5. Discretization (if specified)
  if (!is.null(discretize_cols) && length(discretize_cols) > 0) {
    for (col in discretize_cols) {
      if (col %in% names(df_processed) && is.numeric(df_processed[[col]])) {
        df_processed[[col]] <- cut(df_processed[[col]], breaks = 5, labels = paste0("Bin", 1:5))
        changes_log[[col]] <- "discretized into 5 bins"
      }
    }
  }
  
  return(list(data = df_processed, log = changes_log))
}

# Feature selection methods
feature_selection <- function(df, target, method = "correlation", top_n = 10) {
  if (is.null(target) || target == "none") return(NULL)
  
  predictors <- setdiff(names(df), target)
  if (length(predictors) == 0) return(NULL)
  
  if (method == "correlation") {
    if (is.numeric(df[[target]])) {
      cors <- sapply(df[, predictors, drop = FALSE], function(x) {
        if (is.numeric(x)) abs(cor(x, df[[target]], use = "complete.obs")) else 0
      })
      cors <- sort(cors, decreasing = TRUE)
      return(data.frame(Feature = names(cors), Score = cors))
    } else {
      # For classification, use ANOVA F-value
      f_values <- sapply(df[, predictors, drop = FALSE], function(x) {
        if (is.numeric(x)) {
          summary(aov(df[[target]] ~ x))[[1]]$`F value`[1]
        } else 0
      })
      f_values <- sort(f_values, decreasing = TRUE)
      return(data.frame(Feature = names(f_values), Score = f_values))
    }
  } else if (method == "information_gain") {
    # Simplified: use varImp from caret
    # For demonstration, use correlation as proxy
    return(feature_selection(df, target, "correlation", top_n))
  } else if (method == "chi_square") {
    # For categorical target and numeric/categorical predictors
    chi_results <- sapply(df[, predictors, drop = FALSE], function(x) {
      if (is.factor(df[[target]])) {
        tbl <- table(x, df[[target]])
        if (min(dim(tbl)) > 1) {
          chisq.test(tbl)$statistic
        } else 0
      } else 0
    })
    chi_results <- sort(chi_results, decreasing = TRUE)
    return(data.frame(Feature = names(chi_results), Score = chi_results))
  }
  return(NULL)
}

# Model training function (enhanced)
train_models_enhanced <- function(train_data, test_data, target, problem_type) {
  results <- list()
  
  predictors <- setdiff(names(train_data), target)
  X_train <- train_data[, predictors, drop = FALSE]
  y_train <- train_data[[target]]
  X_test <- test_data[, predictors, drop = FALSE]
  y_test <- test_data[[target]]
  
  if (problem_type == "classification") {
    y_train <- as.factor(y_train)
    y_test <- as.factor(y_test)
    
    # Random Forest
    tryCatch({
      rf <- randomForest(x = X_train, y = y_train, ntree = 100, importance = TRUE)
      pred <- predict(rf, X_test)
      cm <- confusionMatrix(pred, y_test)
      results[["Random Forest"]] <- list(
        accuracy = cm$overall["Accuracy"],
        precision = mean(cm$byClass[, "Precision"], na.rm = TRUE),
        recall = mean(cm$byClass[, "Sensitivity"], na.rm = TRUE),
        f1 = mean(cm$byClass[, "F1"], na.rm = TRUE),
        predictions = pred,
        model = rf
      )
    }, error = function(e) NULL)
    
    # XGBoost
    tryCatch({
      X_train_mat <- as.matrix(X_train)
      X_test_mat <- as.matrix(X_test)
      y_train_num <- as.numeric(y_train) - 1
      num_class <- length(unique(y_train_num))
      params <- list(objective = ifelse(num_class == 2, "binary:logistic", "multi:softmax"),
                     num_class = num_class, max_depth = 6, eta = 0.3, nrounds = 100)
      xgb <- xgboost(data = X_train_mat, label = y_train_num, nrounds = 100, 
                     objective = params$objective, num_class = num_class, verbose = 0)
      pred_prob <- predict(xgb, X_test_mat)
      if (num_class == 2) {
        pred <- factor(ifelse(pred_prob > 0.5, levels(y_train)[2], levels(y_train)[1]), levels = levels(y_train))
      } else {
        pred <- factor(pred_prob, levels = 0:(num_class-1), labels = levels(y_train))
      }
      cm <- confusionMatrix(pred, y_test)
      results[["XGBoost"]] <- list(
        accuracy = cm$overall["Accuracy"],
        precision = mean(cm$byClass[, "Precision"], na.rm = TRUE),
        recall = mean(cm$byClass[, "Sensitivity"], na.rm = TRUE),
        f1 = mean(cm$byClass[, "F1"], na.rm = TRUE),
        predictions = pred,
        model = xgb
      )
    }, error = function(e) NULL)
    
    # SVM
    tryCatch({
      svm_model <- svm(x = X_train, y = y_train, kernel = "radial", probability = TRUE)
      pred <- predict(svm_model, X_test)
      cm <- confusionMatrix(pred, y_test)
      results[["SVM"]] <- list(
        accuracy = cm$overall["Accuracy"],
        precision = mean(cm$byClass[, "Precision"], na.rm = TRUE),
        recall = mean(cm$byClass[, "Sensitivity"], na.rm = TRUE),
        f1 = mean(cm$byClass[, "F1"], na.rm = TRUE),
        predictions = pred,
        model = svm_model
      )
    }, error = function(e) NULL)
    
    # Logistic Regression
    tryCatch({
      log_model <- glm(as.formula(paste(target, "~ .")), data = train_data, family = binomial())
      pred_prob <- predict(log_model, X_test, type = "response")
      pred <- factor(ifelse(pred_prob > 0.5, levels(y_train)[2], levels(y_train)[1]), levels = levels(y_train))
      cm <- confusionMatrix(pred, y_test)
      results[["Logistic Regression"]] <- list(
        accuracy = cm$overall["Accuracy"],
        precision = cm$byClass["Precision"],
        recall = cm$byClass["Sensitivity"],
        f1 = cm$byClass["F1"],
        predictions = pred,
        model = log_model
      )
    }, error = function(e) NULL)
    
  } else { # Regression
    # Linear Regression
    tryCatch({
      lm_model <- lm(as.formula(paste(target, "~ .")), data = train_data)
      pred <- predict(lm_model, X_test)
      rmse <- sqrt(mean((pred - y_test)^2))
      mae <- mean(abs(pred - y_test))
      rsq <- summary(lm_model)$r.squared
      adj_rsq <- summary(lm_model)$adj.r.squared
      results[["Linear Regression"]] <- list(
        rmse = rmse, mae = mae, rsq = rsq, adj_rsq = adj_rsq,
        predictions = pred, model = lm_model
      )
    }, error = function(e) NULL)
    
    # Random Forest Regression
    tryCatch({
      rf <- randomForest(x = X_train, y = y_train, ntree = 100, importance = TRUE)
      pred <- predict(rf, X_test)
      rmse <- sqrt(mean((pred - y_test)^2))
      mae <- mean(abs(pred - y_test))
      rsq <- cor(pred, y_test)^2
      results[["Random Forest"]] <- list(
        rmse = rmse, mae = mae, rsq = rsq, adj_rsq = rsq,
        predictions = pred, model = rf
      )
    }, error = function(e) NULL)
    
    # XGBoost Regression
    tryCatch({
      X_train_mat <- as.matrix(X_train)
      X_test_mat <- as.matrix(X_test)
      xgb <- xgboost(data = X_train_mat, label = y_train, nrounds = 100, 
                     objective = "reg:squarederror", verbose = 0)
      pred <- predict(xgb, X_test_mat)
      rmse <- sqrt(mean((pred - y_test)^2))
      mae <- mean(abs(pred - y_test))
      rsq <- cor(pred, y_test)^2
      results[["XGBoost"]] <- list(
        rmse = rmse, mae = mae, rsq = rsq, adj_rsq = rsq,
        predictions = pred, model = xgb
      )
    }, error = function(e) NULL)
    
    # Ridge Regression
    tryCatch({
      ridge <- train(x = X_train, y = y_train, method = "ridge", preProcess = c("center", "scale"))
      pred <- predict(ridge, X_test)
      rmse <- sqrt(mean((pred - y_test)^2))
      mae <- mean(abs(pred - y_test))
      rsq <- cor(pred, y_test)^2
      results[["Ridge Regression"]] <- list(
        rmse = rmse, mae = mae, rsq = rsq, adj_rsq = rsq,
        predictions = pred, model = ridge
      )
    }, error = function(e) NULL)
  }
  
  return(results)
}

# Clustering function (enhanced)
perform_clustering_enhanced <- function(data, k_min = 2, k_max = 10) {
  numeric_data <- data[, sapply(data, is.numeric), drop = FALSE]
  if (ncol(numeric_data) < 2) return(list(error = "Need at least 2 numeric columns for clustering"))
  
  scaled_data <- scale(numeric_data)
  
  # Elbow method
  wss <- sapply(k_min:k_max, function(k) {
    kmeans(scaled_data, centers = k, nstart = 25)$tot.withinss
  })
  
  # Silhouette scores
  sil <- sapply(k_min:k_max, function(k) {
    km <- kmeans(scaled_data, centers = k, nstart = 25)
    ss <- silhouette(km$cluster, dist(scaled_data))
    mean(ss[, 3])
  })
  
  optimal_k <- k_min + which.max(sil) - 1
  final_km <- kmeans(scaled_data, centers = optimal_k, nstart = 50)
  
  # PCA visualization
  pca <- prcomp(scaled_data, center = TRUE, scale. = TRUE)
  pca_data <- as.data.frame(pca$x[, 1:2])
  pca_data$cluster <- as.factor(final_km$cluster)
  
  # Cluster summaries
  cluster_summary <- aggregate(numeric_data, by = list(Cluster = final_km$cluster), FUN = mean)
  
  list(
    clusters = final_km$cluster,
    optimal_k = optimal_k,
    wss = wss, sil_scores = sil,
    k_values = k_min:k_max,
    pca_data = pca_data,
    cluster_summary = cluster_summary,
    total_ss = final_km$totss,
    between_ss = final_km$betweenss
  )
}

# Generate insights
generate_insights <- function(data, target, problem_type, model_results, best_model_name, clustering_result = NULL) {
  insights <- list()
  
  if (problem_type == "clustering" && !is.null(clustering_result)) {
    insights$type <- "Clustering Insights"
    insights$text <- c(
      paste("Optimal number of clusters found:", clustering_result$optimal_k),
      paste("Total within-cluster sum of squares:", round(clustering_result$total_ss, 2)),
      paste("Between-cluster sum of squares:", round(clustering_result$between_ss, 2)),
      "Cluster interpretation: Based on feature means, clusters represent distinct groups in the data."
    )
  } else if (problem_type %in% c("classification", "regression")) {
    insights$type <- paste(toupper(problem_type), "Insights")
    insights$best_model <- best_model_name
    if (!is.null(model_results) && length(model_results) > 0) {
      best <- model_results[[best_model_name]]
      if (problem_type == "classification") {
        insights$text <- c(
          paste("Best model:", best_model_name, "with accuracy", round(best$accuracy * 100, 2), "%"),
          paste("F1-score:", round(best$f1 * 100, 2), "%"),
          "The model performs well on the given data.",
          "Important features can be extracted from Random Forest if available."
        )
      } else {
        insights$text <- c(
          paste("Best model:", best_model_name, "with RMSE", round(best$rmse, 4)),
          paste("R-squared:", round(best$rsq, 4)),
          "The model explains a significant portion of variance."
        )
      }
    }
    
    # Correlation insights
    numeric_cols <- names(data)[sapply(data, is.numeric)]
    if (length(numeric_cols) >= 2 && !is.null(target) && target %in% numeric_cols) {
      cors <- cor(data[, numeric_cols], use = "complete.obs")
      target_cors <- cors[target, setdiff(numeric_cols, target)]
      high_corr <- names(target_cors[abs(target_cors) > 0.5])
      if (length(high_corr) > 0) {
        insights$text <- c(insights$text, paste("Strongly correlated features with target:", paste(high_corr, collapse = ", ")))
      }
    }
  }
  
  return(insights)
}

